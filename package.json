{
"name": "jonah",
"version": "1.0.0",
"main": "main.js",
"description": "Jonah AI Browser",
"author": "Shaun [shaun@example.com](mailto:shaun@example.com)",
"license": "ISC",
"scripts": {
"start": "electron .",
"build": "electron-builder --win"
},
"devDependencies": {
"electron": "22.3.27",
"electron-builder": "^24.13.3"
},
"build": {
"appId": "com.jonah.browser",
"productName": "Jonah",
"win": {
"target": [
{
"target": "nsis",
"arch": ["x64", "ia32"]
}
],
"icon": "assets/Jonah.ico",
"signAndEditExecutable": false
},
"linux": {
"target": ["AppImage", "deb"],
"category": "Utility"
}
},
"dependencies": {
"@cliqz/adblocker-electron": "^1.34.0",
"axios": "^1.13.5",
"cors": "^2.8.6",
"cross-fetch": "^4.1.0",
"dotenv": "^17.3.1",
"express": "^5.2.1"
}
}
