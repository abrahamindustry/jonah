{
  "name": "jonah",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Jonah AI Browser",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.jonah.browser",
    "productName": "Jonah",

    "win": {
      "target": "nsis",
      "icon": "assets/Jonah.ico",
      "signAndEditExecutable": true
    },

    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities",
      "icon": "assets/Jonah.icns"
    }
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  }
}